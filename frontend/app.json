{
  "expo": {
    "name": "LifeMax",
    "slug": "lifemax-v2",
    "owner": "pavsidk",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "lifemax",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
