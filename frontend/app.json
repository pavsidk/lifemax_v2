      "bundleIdentifier": "com.lifemax.v2"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B0B15"
      },
      "package": "com.lifemax.v2"
    },
    "plugins": [
      "expo-web-browser"
    ],
    "extra": {
      "googleWebClientId": "156107022023-94l3vlsm4qdtkcejn1i9e1vpatfmapko.apps.googleusercontent.com"
    }
  }
